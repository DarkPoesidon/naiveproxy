render_caddyfile() {
  load_config || die "Configuration is missing. Run: sudo naive-server install"
  local fallback upstream_line
  upstream_line=""
  [[ "${OUTBOUND_MODE:-direct}" == "direct" ]] || upstream_line="    upstream ${SOCKS_UPSTREAM}"

  case "$DECOY_MODE" in
    generated|directory)
      fallback="    root * ${DECOY_ROOT}
    file_server"
      ;;
    reverse_proxy)
      fallback="    reverse_proxy ${DECOY_UPSTREAM}"
      ;;
    *) die "Unknown decoy mode: $DECOY_MODE" ;;
  esac

  install -d -m 0700 "$CONFIG_DIR"
  cat >"$CADDYFILE" <<EOF
{
  log {
    exclude http.log.error
  }
}

:443, ${DOMAIN} {
  tls ${ACME_EMAIL}
  encode zstd gzip
  route {
    forward_proxy {
      basic_auth ${PROXY_USER} ${PROXY_PASS}
      hide_ip
      hide_via
      probe_resistance
${upstream_line}
    }
${fallback}
  }
}
EOF
  chmod 0640 "$CADDYFILE"
  chown root:caddy "$CADDYFILE"
}

validate_caddyfile() {
  "$CADDY_BIN" validate --config "$CADDYFILE" --adapter caddyfile
}

reload_service_with_rollback() {
  local previous
  previous="$(mktemp)"
  [[ -f "$CADDYFILE" ]] && cp "$CADDYFILE" "$previous"
  render_caddyfile
  if ! validate_caddyfile; then
    cp "$previous" "$CADDYFILE" 2>/dev/null || true
    rm -f "$previous"
    warn "Caddy rejected the new configuration. The previous Caddyfile was restored."
    return 1
  fi
  if ! systemctl restart "$SERVICE_NAME"; then
    cp "$previous" "$CADDYFILE" 2>/dev/null || true
    systemctl restart "$SERVICE_NAME" 2>/dev/null || true
    rm -f "$previous"
    warn "Service restart failed. The previous Caddyfile was restored."
    return 1
  fi
  rm -f "$previous"
}

explain_dns() {
  hr
  say "${BOLD}Step 1: Domain name${RESET}"
  say "Your domain is the normal-looking website address used by the client."
  say "Before continuing, create an A record in your DNS provider:"
  say
  say "  Type: A"
  say "  Name: your chosen subdomain, such as notes"
  say "  Value: this server's public IPv4 address"
  say "  Proxy/CDN mode: DNS only"
  say
  say "Do not enable the Cloudflare orange-cloud proxy. NaiveProxy clients need"
  say "to reach this server directly using standard HTTPS CONNECT requests."
  hr
}

ask_domain() {
  explain_dns
  while true; do
    DOMAIN="$(ask_value "Enter the complete domain, for example notes.example.com" "${DOMAIN:-}")"
    DOMAIN="${DOMAIN,,}"
    validate_domain_format "$DOMAIN" && break
    warn "Enter only a valid complete domain. Do not include https:// or a path."
  done
  local resolved public_ip
  resolved="$(dig +short A "$DOMAIN" | paste -sd ', ' -)"
  if [[ -n "$resolved" ]]; then
    ok "$DOMAIN currently resolves to: $resolved"
  else
    warn "$DOMAIN does not currently have an IPv4 DNS result."
    say "TLS certificate creation will fail until DNS points to this server."
    ask_yes_no "Continue after confirming you will fix DNS before validation?" "n" ||
      die "Stopped. Create the DNS record, wait for it to update, then run the installer again."
  fi
  public_ip="$(curl -4fsS --max-time 10 https://api.ipify.org || true)"
  if [[ -n "$public_ip" && -n "$resolved" ]] && ! grep -qw "$public_ip" <<<"$resolved"; then
    warn "This server appears to use public IPv4 $public_ip, but $DOMAIN resolves to: $resolved"
    say "If this server has a different NAT or floating IP, that may be intentional."
    ask_yes_no "Continue after confirming the DNS record is correct for this server?" "n" ||
      die "Stopped. Fix DNS, wait for it to update, then run the installer again."
  fi
}

ask_email() {
  hr
  say "${BOLD}Step 2: TLS certificate email${RESET}"
  say "Caddy automatically requests and renews a trusted HTTPS certificate."
  say "Enter a real email address so the certificate authority can send notices."
  while true; do
    ACME_EMAIL="$(ask_value "ACME email address" "${ACME_EMAIL:-}")"
    validate_email_format "$ACME_EMAIL" && break
    warn "Enter a valid email address."
  done
}

ask_credentials() {
  hr
  say "${BOLD}Step 3: Proxy login${RESET}"
  say "This private username and password will be placed in your client app."
  say "Generated credentials are recommended because weak passwords can expose the proxy."
  if ask_yes_no "Generate a strong username and password automatically?" "y"; then
    PROXY_USER="user$(openssl rand -hex 4)"
    PROXY_PASS="$(generate_secret)"
    ok "Secure credentials generated."
  else
    while true; do
      PROXY_USER="$(ask_value "Proxy username")"
      [[ "$PROXY_USER" =~ ^[A-Za-z0-9._-]+$ ]] && break
      warn "Use letters, numbers, dot, underscore, or dash only."
    done
    while true; do
      PROXY_PASS="$(ask_value "Proxy password")"
      [[ "$PROXY_PASS" =~ ^[A-Za-z0-9._-]{12,}$ ]] && break
      warn "Use at least 12 characters: letters, numbers, dot, underscore, or dash."
    done
  fi
}

ask_decoy() {
  hr
  say "${BOLD}Step 4: Normal-looking website${RESET}"
  say "Visitors and unauthenticated probes must see a normal HTTPS website."
  say "NaiveProxy clients also fetch its CSS, JavaScript, and images as browser-like"
  say "preamble traffic. A realistic multi-asset site is materially better than a blank page."
  say
  say "  1. Generate a ready-to-use small website (recommended)"
  say "  2. Serve an existing website directory on this server"
  say "  3. Reverse proxy a real website you control (advanced)"
  local choice
  choice="$(ask_value "Choose website mode" "1")"
  case "$choice" in
    1)
      DECOY_MODE="generated"
      DECOY_ROOT="$WWW_DIR"
      DECOY_UPSTREAM=""
      create_generated_decoy
      ;;
    2)
      DECOY_MODE="directory"
      DECOY_ROOT="$(ask_value "Absolute website directory, for example /var/www/html")"
      [[ "$DECOY_ROOT" == /* && -d "$DECOY_ROOT" && -f "$DECOY_ROOT/index.html" ]] ||
        die "The directory must exist and contain index.html."
      DECOY_UPSTREAM=""
      ;;
    3)
      DECOY_MODE="reverse_proxy"
      DECOY_UPSTREAM="$(ask_value "Website origin URL, for example https://www.example.com")"
      [[ "$DECOY_UPSTREAM" =~ ^https?:// ]] || die "Origin URL must start with http:// or https://"
      DECOY_ROOT="$WWW_DIR"
      warn "Use only a website you control. Do not impersonate another organization."
      ;;
    *) die "Invalid website mode." ;;
  esac
}

ask_outbound() {
  hr
  say "${BOLD}Step 5: Outbound route${RESET}"
  say "Direct outbound is the reliable default. Destination websites will see this"
  say "server's IP address. An optional local SOCKS5 proxy can change that exit IP."
  say
  say "  1. Direct outbound (recommended)"
  say "  2. Existing local SOCKS5 proxy (advanced)"
  say "  3. Cloudflare WARP local SOCKS5 proxy (experimental)"
  local choice
  choice="$(ask_value "Choose outbound mode" "1")"
  case "$choice" in
    1)
      OUTBOUND_MODE="direct"
      SOCKS_UPSTREAM=""
      ;;
    2)
      OUTBOUND_MODE="socks5"
      SOCKS_UPSTREAM="$(ask_value "SOCKS5 URL" "socks5://127.0.0.1:1080")"
      validate_socks_upstream "$SOCKS_UPSTREAM" || die "SOCKS5 validation failed. No configuration was changed."
      ;;
    3)
      configure_warp
      ;;
    *) die "Invalid outbound mode." ;;
  esac
}

validate_socks_upstream() {
  local upstream="$1"
  [[ "$upstream" =~ ^socks5://127\.0\.0\.1:[0-9]+$ ]] || {
    warn "For safety, this guided installer accepts only a local SOCKS5 listener."
    return 1
  }
  info "Testing SOCKS5 route: $upstream"
  curl -fsS --max-time 20 --socks5-hostname "${upstream#socks5://}" https://www.cloudflare.com/cdn-cgi/trace >/dev/null
}

install_warp_package() {
  info "Installing Cloudflare's Linux WARP package repository..."
  apt-get install -y gnupg lsb-release
  install -d -m 0755 /usr/share/keyrings
  curl -fsSL https://pkg.cloudflareclient.com/pubkey.gpg |
    gpg --dearmor --yes -o /usr/share/keyrings/cloudflare-warp-archive-keyring.gpg
  printf 'deb [signed-by=/usr/share/keyrings/cloudflare-warp-archive-keyring.gpg] https://pkg.cloudflareclient.com/ %s main\n' \
    "$(lsb_release -cs)" >/etc/apt/sources.list.d/cloudflare-client.list
  apt-get update
  apt-get install -y cloudflare-warp
}

configure_warp() {
  hr
  warn "WARP outbound is experimental."
  say "It can change the IP seen by destination websites. It does not hide this"
  say "server's inbound IP from users or network observers. WARP changes can also"
  say "cause connection failures, so the manager validates the SOCKS5 endpoint first."
  say
  say "Cloudflare's current Local proxy mode listens on 127.0.0.1:40000. Depending"
  say "on your WARP account type, you may need to enroll and configure Local proxy"
  say "mode in Cloudflare Zero Trust before this endpoint becomes available."
  ask_yes_no "Continue with experimental WARP setup?" "n" || {
    OUTBOUND_MODE="direct"
    SOCKS_UPSTREAM=""
    return
  }
  command -v warp-cli >/dev/null 2>&1 || install_warp_package

  say
  say "The installed warp-cli version is:"
  warp-cli --version || true
  say
  say "Trying common consumer WARP local-proxy commands. If your account uses"
  say "Zero Trust enrollment, configure Local proxy mode in the dashboard first."
  warp-cli --accept-tos registration new >/dev/null 2>&1 ||
    warp-cli --accept-tos register >/dev/null 2>&1 || true
  warp-cli --accept-tos mode proxy >/dev/null 2>&1 ||
    warp-cli --accept-tos set-mode proxy >/dev/null 2>&1 || true
  warp-cli --accept-tos proxy port "$WARP_PORT" >/dev/null 2>&1 ||
    warp-cli --accept-tos set-proxy-port "$WARP_PORT" >/dev/null 2>&1 || true
  warp-cli --accept-tos connect >/dev/null 2>&1 || true
  sleep 3

  if validate_socks_upstream "socks5://127.0.0.1:$WARP_PORT"; then
    OUTBOUND_MODE="warp"
    SOCKS_UPSTREAM="socks5://127.0.0.1:$WARP_PORT"
    ok "WARP SOCKS5 endpoint passed the route check."
  else
    warn "WARP SOCKS5 endpoint is not ready. Keeping direct outbound."
    say "Run 'warp-cli --help', complete enrollment if required, then choose"
    say "Outbound route from the naive-server menu and try again."
    OUTBOUND_MODE="direct"
    SOCKS_UPSTREAM=""
  fi
}

print_review() {
  hr
  say "${BOLD}Review before installation${RESET}"
  say "Domain:          $DOMAIN"
  say "TLS email:       $ACME_EMAIL"
  say "Website mode:    $DECOY_MODE"
  say "Outbound route:  ${OUTBOUND_MODE:-direct}"
  say "Allow UDP 443:   ${ENABLE_UDP_443:-yes}"
  say "Proxy username:  $PROXY_USER"
  say "Proxy password:  $PROXY_PASS"
  say
  warn "Store the client details securely. Anyone with this login can use your proxy."
  hr
}

install_flow() {
  require_root
  check_os
  say
  say "${BOLD}$APP_NAME${RESET}"
  say "This wizard installs a private NaiveProxy server behind a normal HTTPS website."
  say "Every step includes a short explanation. You can stop before the final review."
  say
  ask_yes_no "Start the guided installation?" "y" || exit 0
  install_dependencies
  load_config || true
  check_ports
  configure_firewall
  ask_domain
  ask_email
  ask_credentials
  create_service
  ask_decoy
  ask_outbound
  print_review
  ask_yes_no "Apply this configuration and start the service?" "y" ||
    die "Stopped before starting the service."
  apply_firewall
  backup_config
  install_caddy
  save_config
  render_caddyfile
  validate_caddyfile
  systemctl enable --now "$SERVICE_NAME"
  say
  ok "Installation completed."
  validate_all || true
  show_client
}

show_client() {
  load_config || die "Install the server first."
  say
  hr
  say "${BOLD}Client configuration${RESET}"
  say "Use this URL in a NaiveProxy-compatible client:"
  say
  say "  naive+https://${PROXY_USER}:${PROXY_PASS}@${DOMAIN}:443"
  say
  say "For the standalone naive client, create config.json:"
  cat <<EOF
{
  "listen": "socks://127.0.0.1:1080",
  "proxy": "https://${PROXY_USER}:${PROXY_PASS}@${DOMAIN}"
}
EOF
  hr
}

validate_all() {
  require_root
  load_config || die "Install the server first."
  local failures=0
  say
  hr
  say "${BOLD}Server validation${RESET}"
  if validate_caddyfile >/dev/null; then ok "Caddy configuration syntax is valid."; else warn "Caddy configuration is invalid."; failures=$((failures + 1)); fi
  if systemctl is-active --quiet "$SERVICE_NAME"; then ok "Caddy service is running."; else warn "Caddy service is not running."; failures=$((failures + 1)); fi
  if dig +short A "$DOMAIN" | grep -q .; then ok "Domain has an IPv4 DNS record."; else warn "Domain has no IPv4 DNS record."; failures=$((failures + 1)); fi
  if curl -kfsS --max-time 15 --resolve "$DOMAIN:443:127.0.0.1" "https://$DOMAIN/" | grep -Eqi '<html|<!doctype'; then
    ok "Unauthenticated HTTPS visitors receive a normal website."
  else
    warn "Local website probe failed. Check the service logs."
    failures=$((failures + 1))
  fi
  if [[ "$DECOY_MODE" == "generated" ]] &&
    grep -Eq '<link[^>]+href=|<script[^>]+src=|<img[^>]+src=' "$WWW_DIR/index.html"; then
    ok "Generated website contains browser-like CSS, JavaScript, and image assets."
  fi
  if [[ "${OUTBOUND_MODE:-direct}" != "direct" ]]; then
    if validate_socks_upstream "$SOCKS_UPSTREAM"; then ok "Optional SOCKS5 outbound is reachable."; else warn "Optional SOCKS5 outbound failed."; failures=$((failures + 1)); fi
  fi
  if curl -fsS --max-time 25 --proxy "https://${PROXY_USER}:${PROXY_PASS}@${DOMAIN}" https://www.cloudflare.com/cdn-cgi/trace >/dev/null; then
    ok "Authenticated proxy request reached the internet."
  else
    warn "External authenticated proxy test failed."
    say "This often means DNS has not updated yet, TLS issuance is pending, or a firewall blocks port 443."
    failures=$((failures + 1))
  fi
  hr
  [[ "$failures" -eq 0 ]] && ok "All validation checks passed." || warn "$failures validation check(s) need attention."
  return "$failures"
}

show_status() {
  require_root
  load_config || die "Install the server first."
  say
  hr
  say "${BOLD}NaiveProxy server status${RESET}"
  say "Domain:         $DOMAIN"
  say "Website mode:   $DECOY_MODE"
  say "Outbound route: ${OUTBOUND_MODE:-direct}"
  systemctl --no-pager --full status "$SERVICE_NAME" || true
  hr
}

rotate_credentials() {
  require_root
  load_config || die "Install the server first."
  local previous
  previous="$(mktemp)"
  cp "$CONFIG_FILE" "$previous"
  backup_config
  ask_credentials
  save_config
  if ! reload_service_with_rollback; then
    cp "$previous" "$CONFIG_FILE"
    rm -f "$previous"
    die "Credential change failed. Saved configuration was rolled back."
  fi
  rm -f "$previous"
  ok "Credentials updated."
  show_client
}

change_decoy() {
  require_root
  load_config || die "Install the server first."
  local previous
  previous="$(mktemp)"
  cp "$CONFIG_FILE" "$previous"
  backup_config
  ask_decoy
  save_config
  if ! reload_service_with_rollback; then
    cp "$previous" "$CONFIG_FILE"
    rm -f "$previous"
    die "Website change failed. Saved configuration was rolled back."
  fi
  rm -f "$previous"
  ok "Website mode updated."
}

change_outbound() {
  require_root
  load_config || die "Install the server first."
  local previous
  previous="$(mktemp)"
  cp "$CONFIG_FILE" "$previous"
  ask_outbound
  save_config
  if ! reload_service_with_rollback; then
    cp "$previous" "$CONFIG_FILE"
    rm -f "$previous"
    die "Outbound change failed. Saved configuration was rolled back."
  fi
  rm -f "$previous"
  ok "Outbound route updated."
  validate_all || true
}

uninstall_flow() {
  require_root
  warn "This stops NaiveProxy and removes its service, Caddy binary, and private configuration."
  say "Website files under $WWW_DIR and backups under $BACKUP_DIR are preserved."
  ask_yes_no "Uninstall the NaiveProxy service?" "n" || return 0
  systemctl disable --now "$SERVICE_NAME" 2>/dev/null || true
  rm -f "$SERVICE_FILE" "$CADDY_BIN"
  rm -rf "$CONFIG_DIR"
  systemctl daemon-reload
  ok "NaiveProxy service removed. Website files and backups were preserved."
}

menu() {
  require_root
  while true; do
    say
    hr
    say "${BOLD}$APP_NAME${RESET}"
    say "  1. Install or reinstall server"
    say "  2. Show server status"
    say "  3. Show client configuration"
    say "  4. Change proxy username and password"
    say "  5. Change normal-looking website"
    say "  6. Change outbound route, SOCKS5, or WARP"
    say "  7. Run complete validation"
    say "  8. View recent service logs"
    say "  9. Update Naive-enabled Caddy"
    say " 10. Uninstall service"
    say "  0. Exit"
    hr
    local choice
    choice="$(ask_value "Choose an option")"
    case "$choice" in
      1) install_flow ;;
      2) show_status ;;
      3) show_client ;;
      4) rotate_credentials ;;
      5) change_decoy ;;
      6) change_outbound ;;
      7) validate_all || true ;;
      8) journalctl -u "$SERVICE_NAME" -n 100 --no-pager ;;
      9) install_caddy; systemctl restart "$SERVICE_NAME"; ok "Caddy updated and restarted." ;;
      10) uninstall_flow ;;
      0) exit 0 ;;
      *) warn "Choose a number from the menu." ;;
    esac
    say
    pause
  done
}

case "${1:-menu}" in
  install) install_flow ;;
  status) show_status ;;
  client) show_client ;;
  validate) validate_all ;;
  menu) menu ;;
  *) die "Usage: sudo naive-server [menu|install|status|client|validate]" ;;
esac
