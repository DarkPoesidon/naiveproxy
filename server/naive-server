#!/usr/bin/env bash
set -Eeuo pipefail

APP_NAME="NaiveProxy Server Manager"
CONFIG_DIR="/etc/naiveproxy"
CONFIG_FILE="$CONFIG_DIR/installer.env"
CADDYFILE="$CONFIG_DIR/Caddyfile"
WWW_DIR="/var/www/naiveproxy"
BACKUP_DIR="/var/lib/naiveproxy/backups"
CADDY_BIN="/usr/local/bin/caddy-naive"
SERVICE_FILE="/etc/systemd/system/naiveproxy-caddy.service"
SERVICE_NAME="naiveproxy-caddy"
WARP_PORT="40000"

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

say() { printf '%s\n' "$*"; }
info() { printf '%s[INFO]%s %s\n' "$BLUE" "$RESET" "$*"; }
ok() { printf '%s[OK]%s %s\n' "$GREEN" "$RESET" "$*"; }
warn() { printf '%s[WARNING]%s %s\n' "$YELLOW" "$RESET" "$*"; }
die() { printf '%s[ERROR]%s %s\n' "$RED" "$RESET" "$*" >&2; exit 1; }
hr() { printf '%s\n' "----------------------------------------------------------------"; }

require_root() {
  [[ ${EUID:-$(id -u)} -eq 0 ]] || die "Run this command with sudo: sudo naive-server"
}

pause() {
  read -r -p "Press Enter to continue..." _
}

ask_yes_no() {
  local prompt="$1" default="${2:-y}" answer suffix
  [[ "$default" == "y" ]] && suffix="[Y/n]" || suffix="[y/N]"
  read -r -p "$prompt $suffix: " answer
  answer="${answer:-$default}"
  [[ "$answer" =~ ^[Yy]$ ]]
}

ask_value() {
  local prompt="$1" default="${2:-}" value
  if [[ -n "$default" ]]; then
    read -r -p "$prompt [$default]: " value
    printf '%s' "${value:-$default}"
  else
    read -r -p "$prompt: " value
    printf '%s' "$value"
  fi
}

load_config() {
  [[ -f "$CONFIG_FILE" ]] || return 1
  # This file is written only by this manager and readable only by root.
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
}

save_config() {
  install -d -m 0700 "$CONFIG_DIR"
  umask 077
  {
    printf 'DOMAIN=%q\n' "$DOMAIN"
    printf 'ACME_EMAIL=%q\n' "$ACME_EMAIL"
    printf 'PROXY_USER=%q\n' "$PROXY_USER"
    printf 'PROXY_PASS=%q\n' "$PROXY_PASS"
    printf 'DECOY_MODE=%q\n' "$DECOY_MODE"
    printf 'DECOY_ROOT=%q\n' "${DECOY_ROOT:-$WWW_DIR}"
    printf 'DECOY_UPSTREAM=%q\n' "${DECOY_UPSTREAM:-}"
    printf 'OUTBOUND_MODE=%q\n' "${OUTBOUND_MODE:-direct}"
    printf 'SOCKS_UPSTREAM=%q\n' "${SOCKS_UPSTREAM:-}"
    printf 'ENABLE_UDP_443=%q\n' "${ENABLE_UDP_443:-yes}"
  } >"$CONFIG_FILE"
  chmod 0600 "$CONFIG_FILE"
}

backup_config() {
  [[ -d "$CONFIG_DIR" ]] || return 0
  install -d -m 0700 "$BACKUP_DIR"
  local stamp archive
  stamp="$(date -u +%Y%m%dT%H%M%SZ)"
  archive="$BACKUP_DIR/config-$stamp.tar.gz"
  tar -czf "$archive" -C / etc/naiveproxy 2>/dev/null || true
  chmod 0600 "$archive" 2>/dev/null || true
  info "Configuration backup: $archive"
}

validate_domain_format() {
  [[ "$1" =~ ^[a-z0-9]([a-z0-9.-]*[a-z0-9])?$ && "$1" == *.* ]]
}

validate_email_format() {
  [[ "$1" =~ ^[^[:space:]@]+@[^[:space:]@]+\.[^[:space:]@]+$ ]]
}

generate_secret() {
  openssl rand -base64 36 | tr -dc 'A-Za-z0-9' | head -c 28
}

check_os() {
  [[ -r /etc/os-release ]] || die "This installer supports Debian and Ubuntu servers."
  # shellcheck disable=SC1091
  source /etc/os-release
  case "${ID:-}" in
    debian|ubuntu) ;;
    *) die "Unsupported Linux distribution: ${ID:-unknown}. Use Debian 12+ or Ubuntu 22.04+." ;;
  esac
}

install_dependencies() {
  info "Installing small system tools used for setup and health checks..."
  export DEBIAN_FRONTEND=noninteractive
  apt-get update
  apt-get install -y ca-certificates curl jq openssl tar dnsutils iproute2
}

check_ports() {
  local listeners
  listeners="$(ss -ltnup 2>/dev/null || true)"
  if grep -Eq '(:80 |:80$|:443 |:443$)' <<<"$listeners"; then
    warn "Another program may already use port 80 or 443."
    say "NaiveProxy needs TCP port 443. Caddy also normally uses port 80 to redirect"
    say "visitors and issue TLS certificates. Review these listeners:"
    ss -ltnup | grep -E '(:80 |:443 )' || true
    ask_yes_no "Continue anyway so you can inspect the final validation result?" "n" ||
      die "Stopped before changing the service."
  else
    ok "Ports 80 and 443 do not appear to be occupied."
  fi
}

configure_firewall() {
  hr
  say "${BOLD}Firewall check${RESET}"
  say "Your VPS provider may have a web dashboard firewall or security group."
  say "Open these inbound ports in that dashboard if it has one:"
  say
  say "  TCP 80     HTTPS certificate setup and redirect"
  say "  TCP 443    Required NaiveProxy HTTPS connection"
  say "  UDP 443    Optional QUIC / HTTP/3 connection"
  say
  say "TCP 443 is required. TCP 80 is strongly recommended. UDP 443 improves"
  say "your client choices but HTTPS over TCP still works without it."
  ENABLE_UDP_443="yes"
  ask_yes_no "Allow optional UDP port 443 when configuring a local firewall?" "y" ||
    ENABLE_UDP_443="no"

  if command -v ufw >/dev/null 2>&1 && ufw status | grep -q '^Status: active'; then
    say
    say "The local UFW firewall is active on this server."
    if ask_yes_no "Add the required UFW rules automatically?" "y"; then
      APPLY_UFW="yes"
      info "The UFW rules will be added only after you accept the final review."
    else
      APPLY_UFW="no"
      warn "Remember to add the local firewall rules manually."
    fi
  else
    APPLY_UFW="no"
    info "No active UFW firewall detected. Provider-dashboard rules may still apply."
  fi
}

apply_firewall() {
  [[ "${APPLY_UFW:-no}" == "yes" ]] || return 0
  ufw allow 80/tcp
  ufw allow 443/tcp
  [[ "${ENABLE_UDP_443:-yes}" == "yes" ]] && ufw allow 443/udp
  ok "Local UFW rules added."
}

install_caddy() {
  local arch api url tmpdir archive extracted
  arch="$(uname -m)"
  [[ "$arch" == "x86_64" || "$arch" == "amd64" ]] ||
    die "The upstream prebuilt Naive-enabled Caddy archive is currently used only on x86_64 servers. Detected: $arch"

  info "Downloading the latest Naive-enabled Caddy release from klzgrad/forwardproxy..."
  api="https://api.github.com/repos/klzgrad/forwardproxy/releases/latest"
  url="$(curl -fsSL "$api" | jq -r '.assets[] | select(.name == "caddy-forwardproxy-naive.tar.xz") | .browser_download_url' | head -n1)"
  [[ -n "$url" && "$url" != "null" ]] || die "Could not find the upstream Caddy release archive."

  tmpdir="$(mktemp -d)"
  archive="$tmpdir/caddy.tar.xz"
  trap 'rm -rf "${tmpdir:-}"' RETURN
  curl -fL --retry 3 --connect-timeout 15 "$url" -o "$archive"
  tar -xJf "$archive" -C "$tmpdir"
  extracted="$(find "$tmpdir" -type f -name caddy -print -quit)"
  [[ -n "$extracted" ]] || die "Downloaded archive does not contain the Caddy binary."
  install -m 0755 "$extracted" "$CADDY_BIN"
  "$CADDY_BIN" list-modules | grep -qx 'http.handlers.forward_proxy' ||
    die "Downloaded Caddy binary is missing the Naive forward_proxy module."
  ok "Installed Naive-enabled Caddy: $("$CADDY_BIN" version)"
  trap - RETURN
  rm -rf "$tmpdir"
}

create_service() {
  id -u caddy >/dev/null 2>&1 ||
    useradd --system --home /var/lib/caddy --create-home --shell /usr/sbin/nologin caddy
  install -d -o caddy -g caddy -m 0750 /var/lib/caddy
  cat >"$SERVICE_FILE" <<EOF
[Unit]
Description=NaiveProxy Caddy server
Documentation=https://github.com/klzgrad/naiveproxy
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
User=caddy
Group=caddy
ExecStart=$CADDY_BIN run --environ --config $CADDYFILE --adapter caddyfile
ExecReload=$CADDY_BIN reload --config $CADDYFILE --adapter caddyfile
TimeoutStopSec=5s
LimitNOFILE=1048576
PrivateTmp=true
ProtectSystem=full
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
  systemctl daemon-reload
}

